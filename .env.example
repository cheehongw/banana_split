# --- Telegram ---
# Bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234567890

# Public HTTPS URL where the Mini App frontend is served.
# Set this as the Web App URL in @BotFather (/setmenubutton or via inline button).
WEBAPP_URL=https://your-domain.example

# Public HTTPS URL of THIS server, used for the Telegram webhook.
# Leave empty for local development — the bot falls back to long polling.
SERVER_URL=

# Secret token grammY uses to verify incoming webhook calls (recommended in prod).
WEBHOOK_SECRET=change-me

# --- Server ---
PORT=3000

# --- Database ---
# Path to the SQLite file (created automatically on first run).
DATABASE_URL=./data/banana-split.sqlite
