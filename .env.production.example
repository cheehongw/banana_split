# Production env for the homelab Docker deploy. Copy to `.env` and fill in.
# NEVER commit the real .env. NEVER set DEV_USER_ID here (the server refuses to
# boot with NODE_ENV=production + DEV_USER_ID).

# --- Telegram ---
# Bot token from @BotFather.
BOT_TOKEN=123456:ABC-DEF...

# Public URL of your Tailscale Funnel node (set the same value as the Mini App
# URL in @BotFather). Find it with `tailscale status` / the admin console.
WEBAPP_URL=https://banana.your-tailnet.ts.net

# Leave empty to run the bot in long-polling mode (recommended for the homelab —
# outbound only, no inbound webhook). Only set these to use a webhook instead.
SERVER_URL=
WEBHOOK_SECRET=

# --- Server (defaults baked into the image; override here if needed) ---
# NODE_ENV=production
# PORT=3000
# DATABASE_URL=/data/banana-split.sqlite

# --- Tailscale sidecar ---
# Reusable auth key from the Tailscale admin console (Settings → Keys).
TS_AUTHKEY=tskey-auth-...
